# ─── Banco de dados PostgreSQL ────────────────────────────────────────────────
# Formato: postgresql://user:password@host:5432/dbname

# aria_app — leitura + escrita pela aplicação (DML: INSERT, UPDATE, DELETE)
DATABASE_URL=postgresql://aria_app:password@localhost:5432/aria_bags

# aria_readonly — somente leitura para queries públicas (apenas SELECT)
# Em dev, pode repetir o valor de DATABASE_URL
# Em produção: CREATE USER aria_readonly ...; GRANT SELECT ON ALL TABLES ...
DATABASE_READONLY_URL=postgresql://aria_readonly:password@localhost:5432/aria_bags

# aria_admin — DDL completo, usado APENAS pelo drizzle-kit para migrations
# Nunca usar no runtime da aplicação
# Em dev, pode repetir o valor de DATABASE_URL
DATABASE_ADMIN_URL=postgresql://aria_admin:password@localhost:5432/aria_bags

# better-auth — gerar com: openssl rand -hex 32
BETTER_AUTH_SECRET=your-secret-here

# URL base da aplicação (sem barra no final)
BETTER_AUTH_URL=http://localhost:3000

# URL pública da aplicação (exposta ao browser)
NEXT_PUBLIC_APP_URL=http://localhost:3000
