# ─── Banco de Dados ───────────────────────────────────────────────────────────
# Conexão principal (leitura + escrita). Usuário com permissão DML, SEM DDL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Conexão somente-leitura (opcional). Se não definida, faz fallback para DATABASE_URL.
# Em produção, aponte para um usuário PostgreSQL com apenas SELECT.
#   CREATE USER aria_readonly WITH PASSWORD '...';
#   GRANT CONNECT ON DATABASE aria_bags TO aria_readonly;
#   GRANT SELECT ON ALL TABLES IN SCHEMA public TO aria_readonly;
DATABASE_READONLY_URL="postgresql://aria_readonly:PASSWORD@HOST/DBNAME?sslmode=require"

# ─── Better Auth ──────────────────────────────────────────────────────────────
# Segredo forte com pelo menos 32 caracteres. Gere com:
#   openssl rand -hex 32
BETTER_AUTH_SECRET="SUBSTITUA_POR_SEGREDO_FORTE_DE_PELO_MENOS_32_CHARS"

# URL base da aplicação — DEVE ser HTTPS em produção.
BETTER_AUTH_URL="https://seudominio.com.br"

# ─── App ──────────────────────────────────────────────────────────────────────
# URL pública da aplicação — exposta ao client.
NEXT_PUBLIC_APP_URL="https://seudominio.com.br"
